{
  "name": "claude-code-control",
  "version": "1.0.0",
  "description": "Claude Code Control - tmux controller with Flutter Android app and FastAPI backend",
  "scripts": {
    "dev:backend": "cd backend && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:backend:test": "cd backend && uvicorn app.main:app --reload --host 0.0.0.0 --port 8010",
    "test:e2e": "cd e2e && npx playwright test"
  },
  "keywords": [
    "claude-code",
    "tmux",
    "remote-development",
    "terminal",
    "flutter",
    "fastapi"
  ],
