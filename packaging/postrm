#!/bin/bash
set -e

# Only remove venv on actual removal, not on abort-install/abort-upgrade
# (which would destroy a working venv after a transient pip failure)
if [ "$1" = "remove" ] || [ "$1" = "purge" ]; then
    rm -rf /opt/claude-code-control/venv
fi

if [ "$1" = "purge" ]; then
    rm -rf /etc/claude-code-control
    rm -rf /etc/systemd/system/claude-code-control.service.d
    rm -rf /var/lib/claude-code-control
fi

if [ -d /run/systemd/system ]; then
    systemctl daemon-reload
fi
