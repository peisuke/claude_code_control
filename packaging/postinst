#!/bin/bash
set -e

INSTALL_DIR="/opt/claude-code-control"
DROPIN_DIR="/etc/systemd/system/claude-code-control.service.d"
DROPIN_FILE="$DROPIN_DIR/user.conf"

# --- 1. Create/update venv (offline, no network required) ---
echo "--- Setting up Python venv ---"
python3 -m venv "$INSTALL_DIR/venv"
"$INSTALL_DIR/venv/bin/pip" install --upgrade pip --quiet
"$INSTALL_DIR/venv/bin/pip" install -r "$INSTALL_DIR/requirements.txt" --quiet
echo "Dependencies installed."

# --- 2. Configure service user (fresh install only) ---
if [ ! -f "$DROPIN_FILE" ]; then
    RUN_USER="${SUDO_USER:-}"

    # Refuse to run as root — the service needs access to a real user's tmux sockets
    if [ -z "$RUN_USER" ] || [ "$RUN_USER" = "root" ]; then
        echo ""
        echo "ERROR: Could not detect a non-root user."
        echo "  Install with: sudo dpkg -i claude-code-control_*.deb"
        echo "  (SUDO_USER must be set to a non-root user)"
        echo ""
        echo "  Or configure manually after install:"
        echo "    sudo mkdir -p $DROPIN_DIR"
        echo "    echo -e '[Service]\nUser=YOUR_USER\nGroup=YOUR_GROUP' | sudo tee $DROPIN_FILE"
        echo "    sudo systemctl daemon-reload"
        echo ""
        exit 1
    fi

    RUN_GROUP="$(id -gn "$RUN_USER" 2>/dev/null || echo root)"

    mkdir -p "$DROPIN_DIR"
    cat > "$DROPIN_FILE" <<DROPIN
[Service]
User=$RUN_USER
Group=$RUN_GROUP
DROPIN

    if [ "$RUN_USER" != "root" ]; then
        echo "Service user set to: $RUN_USER"
    fi
fi

# Read back the configured user for state directory ownership
CONFIGURED_USER="$(grep -oP '^User=\K.*' "$DROPIN_FILE" 2>/dev/null || echo root)"
CONFIGURED_GROUP="$(grep -oP '^Group=\K.*' "$DROPIN_FILE" 2>/dev/null || echo root)"

# --- 3. State directory ---
mkdir -p /var/lib/claude-code-control
chown "$CONFIGURED_USER:$CONFIGURED_GROUP" /var/lib/claude-code-control

# --- 4. Enable and restart ---
systemctl daemon-reload
systemctl enable claude-code-control.service

if [ "$1" = "configure" ] && systemctl is-active --quiet claude-code-control.service 2>/dev/null; then
    systemctl restart claude-code-control.service
    echo "Service restarted after upgrade."
fi

echo ""
echo "Claude Code Control installed successfully!"
echo ""
echo "  Service user: $CONFIGURED_USER"
echo "  Config:       /etc/claude-code-control/config.env"
echo "  State:        /var/lib/claude-code-control/"
echo "  Start:        sudo systemctl start claude-code-control"
echo "  Logs:         journalctl -u claude-code-control -f"
echo ""
