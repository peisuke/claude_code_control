# Claude Code Control configuration
# This file is read by the systemd service.

# Listen address and port
# Default: localhost only. Set to 0.0.0.0 for LAN access (no auth — use with caution).
HOST=127.0.0.1
PORT=8192

# CORS allowed origins (JSON array)
# Examples:
#   CORS_ORIGINS=["http://192.168.1.100:8192"]
#   CORS_ORIGINS=["*"]
#CORS_ORIGINS=["*"]

# tmux socket path (optional, auto-detected if unset)
# Set this if tmux uses a non-default socket location.
#TMUX_SOCKET_PATH=/tmp/tmux-1000/default
